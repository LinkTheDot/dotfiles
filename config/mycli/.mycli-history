+-- Find the longest consecutive sequence starting with "syadouBiggly1 syadouBiggly2" 
+-- followed by consecutive "syadouBiggly3 syadouBiggly4" messages
+WITH ordered_messages AS (
+    -- Step 1: Get all messages in chronological order with row numbers
+    SELECT 
+        id,
+        contents,
+        timestamp,
+        ROW_NUMBER() OVER (ORDER BY timestamp) as row_num
+    FROM stream_message
+    ORDER BY timestamp
+),
+
+starter_positions AS (
+    -- Step 2: Find all positions where the starter message appears
+    SELECT 
+        id,
+        timestamp,
+        row_num
+    FROM ordered_messages
+    WHERE contents = 'syadouBiggly1 syadouBiggly2'
+),
+
+sequence_analysis AS (
+    -- Step 3: For each starter, count how many consecutive repeaters follow
+    SELECT 
+        sp.id as starter_id,
+        sp.timestamp as starter_timestamp,
+        sp.row_num as starter_row,
+        (
+            -- Count consecutive "syadouBiggly3 syadouBiggly4" messages immediately following the starter
+            SELECT COUNT(*)
+            FROM ordered_messages om
+            WHERE om.row_num > sp.row_num
+            AND om.contents = 'syadouBiggly3 syadouBiggly4'
+            AND om.row_num <= sp.row_num + (
+                -- Find where the sequence breaks (first non-matching message after starter)
+                SELECT COALESCE(MIN(break_om.row_num), sp.row_num + 1000) - 1
+                FROM ordered_messages break_om
+                WHERE break_om.row_num > sp.row_num 
+                AND break_om.contents != 'syadouBiggly3 syadouBiggly4'
+            )
+        ) as consecutive_repeater_count
+    FROM starter_positions sp
+),
+
+longest_sequence AS (
+    -- Step 4: Find the starter with the most consecutive repeaters
+    SELECT 
+        starter_id,
+        starter_timestamp,
+        starter_row,
+        consecutive_repeater_count
+    FROM sequence_analysis
+    WHERE consecutive_repeater_count = (
+        SELECT MAX(consecutive_repeater_count) 
+        FROM sequence_analysis
+    )
+    LIMIT 1
+)
+
+-- Step 5: Return all messages in the longest sequence
+SELECT 
+    CASE 
+        WHEN om.contents = 'syadouBiggly1 syadouBiggly2' THEN 'starter'
+        ELSE 'repeater'
+    END as message_role,
+    om.id,
+    om.contents,
+    om.timestamp,
+    ls.consecutive_repeater_count as total_repeater_count,
+    CASE 
+        WHEN om.contents = 'syadouBiggly1 syadouBiggly2' THEN 0
+        ELSE om.row_num - ls.starter_row
+    END as sequence_position
+FROM longest_sequence ls
+JOIN ordered_messages om ON (
+    om.row_num >= ls.starter_row 
+    AND om.row_num <= ls.starter_row + ls.consecutive_repeater_count
+    AND (
+        om.contents = 'syadouBiggly1 syadouBiggly2' 
+        OR om.contents = 'syadouBiggly3 syadouBiggly4'
+    )
+)
+ORDER BY om.timestamp;
