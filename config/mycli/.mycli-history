+-- Simplified MySQL 5.7 approach - finds the longest consecutive sequence
+-- This query finds all messages in the longest sequence in one go
+
+SELECT 
+    CASE 
+        WHEN sm.contents = 'syadouBiggly1 syadouBiggly2' THEN 'starter'
+        ELSE 'repeater'
+    END as message_role,
+    sm.id,
+    sm.contents,
+    sm.timestamp,
+    best_sequence.consecutive_count as total_repeater_count
+FROM stream_message sm
+INNER JOIN (
+    -- Find the starter message with the most consecutive repeaters
+    SELECT 
+        starter.id as starter_id,
+        starter.timestamp as starter_timestamp,
+        COUNT(repeater.id) as consecutive_count,
+        COALESCE(MAX(repeater.timestamp), starter.timestamp) as sequence_end_timestamp
+    FROM stream_message starter
+    LEFT JOIN stream_message repeater ON (
+        repeater.timestamp > starter.timestamp
+        AND repeater.contents = 'syadouBiggly3 syadouBiggly4'
+        -- Ensure no non-repeater messages exist between starter and this repeater
+        AND NOT EXISTS (
+            SELECT 1 FROM stream_message break_msg
+            WHERE break_msg.timestamp > starter.timestamp
+            AND break_msg.timestamp < repeater.timestamp
+            AND break_msg.contents != 'syadouBiggly3 syadouBiggly4'
+        )
+        -- Ensure this repeater comes immediately after previous repeater (no gaps)
+        AND NOT EXISTS (
+            SELECT 1 FROM stream_message earlier_repeater
+            WHERE earlier_repeater.timestamp > starter.timestamp
+            AND earlier_repeater.timestamp < repeater.timestamp
+            AND earlier_repeater.contents = 'syadouBiggly3 syadouBiggly4'
+            AND EXISTS (
+                SELECT 1 FROM stream_message gap_msg
+                WHERE gap_msg.timestamp > earlier_repeater.timestamp
+                AND gap_msg.timestamp < repeater.timestamp
+                AND gap_msg.contents != 'syadouBiggly3 syadouBiggly4'
+            )
+        )
+    )
+    WHERE starter.contents = 'syadouBiggly1 syadouBiggly2'
+    GROUP BY starter.id, starter.timestamp
+    ORDER BY consecutive_count DESC, starter.timestamp
+    LIMIT 1
+) best_sequence ON (
+    sm.timestamp >= best_sequence.starter_timestamp
+    AND sm.timestamp <= best_sequence.sequence_end_timestamp
+    AND sm.contents IN ('syadouBiggly1 syadouBiggly2', 'syadouBiggly3 syadouBiggly4')
+)
+ORDER BY sm.timestamp;

