# Favorite queries.
# You can add your favorite queries here. They will be available in the
# REPL when you type `\f` or `\f <query_name>`.
[favorite_queries]
get_users = SELECT * FROM twitch_user;
CordiesDonation = SELECT * FROM donation_event WHERE stream_id = (SELECT id FROM stream WHERE twitch_user_id = 1 ORDER BY id DESC LIMIT 1) AND donator_twitch_user_id = (SELECT id FROM twitch_user WHERE login_name = 'cordiesd1e');
GetUser = SELECT * FROM twitch_user WHERE login_name like '%$1%';
\e = '''get_donations SELECT 
  de.id, 
  de.event_type, 
  de.timestamp, 
  tu_donator.login_name AS donator_login_name,
  tu_receiver.login_name AS donation_receiver_login_name,
  de.stream_id,
  CASE
    WHEN de.subscription_tier IS NOT NULL
    THEN de.subscription_tier
    ELSE NULL
  END AS subscription_tier,  
  CASE
    WHEN de.unknown_user_id IS NOT NULL
    THEN de.unknown_user_id
    ELSE NULL
  END AS unknown_user
FROM donation_event AS de
LEFT JOIN twitch_user AS tu_donator ON de.donator_twitch_user_id = tu_donator.id
LEFT JOIN twitch_user AS tu_receiver ON de.donation_receiver_login_name = tu_receiver.id;'''
GetUserMessagesFromLogin = '''SELECT sm.id, 
  sm.is_first_message, 
  sm.timestamp, 
  sm.contents, 
  chatter.login_name AS chatter, 
  streamer.login_name AS streamer, 
  sm.stream_id, 
  sm.third_party_emotes_used, 
  sm.twitch_emote_usage, 
  sm.is_subscriber 
FROM stream_message AS sm 
JOIN twitch_user AS chatter ON sm.twitch_user_id = chatter.id 
JOIN twitch_user AS streamer ON sm.channel_id = streamer.id 
WHERE sm.twitch_user_id = GetUserIdFromLogin('$1');'''
DayOf = select * from stream_message where contents like '%Day % of-%' and twitch_user_id = GetUserIdFromLogin('linkthedot');
timeouts = '''SELECT 
  user_timeout.id, user_timeout.duration, user_timeout.timestamp, banned_user.login_name as banned_user, streamer.login_name as streamer, user_timeout.stream_id
FROM user_timeout
JOIN
  twitch_user AS streamer ON user_timeout.channel_id = streamer.id
JOIN
  twitch_user AS banned_user ON user_timeout.twitch_user_id = banned_user.id'''
GetDonations = '''SELECT
de.id,
de.event_type,
de.amount,
de.timestamp,
tu_donator.login_name AS donator_login_name,
tu_receiver.login_name AS donation_receiver_login_name,
de.stream_id,
de.subscription_tier,
unknown_user.name as unknown_user_name
FROM donation_event AS de
LEFT JOIN twitch_user AS tu_donator ON de.donator_twitch_user_id = tu_donator.id
LEFT JOIN twitch_user AS tu_receiver ON de.donation_receiver_twitch_user_id = tu_receiver.id
LEFT JOIN unknown_user ON de.unknown_user_id = unknown_user.id'''
GetSubscriptions = '''SELECT
se.id,
se.timestamp,
tu_subscriber.login_name AS subscriber_login_name,
tu_receiver.login_name AS subscription_receiver_login_name,
se.stream_id,
se.subscription_tier
FROM subscription_event AS se
LEFT JOIN twitch_user AS tu_subscriber ON se.subscriber_twitch_user_id = tu_subscriber.id
LEFT JOIN twitch_user AS tu_receiver ON se.channel_id = tu_receiver.id'''
LatestMessages = '''SELECT
  sm.id,
  sm.is_first_message,
  sm.timestamp,
  sm.contents,
  twitch_user.login_name,
  sm.channel_id,
  sm.stream_id,
  sm.is_subscriber
FROM stream_message as sm
INNER JOIN twitch_user ON sm.twitch_user_id = twitch_user.id
ORDER BY timestamp DESC LIMIT $1;'''
CheckExists = '''
SELECT * from gift_sub_recipient where donation_event_id in ($1)'''
FixExisting = update gift_sub_recipient set donation_event_id = $1 where donation_event_id in ($2)
RemoveDupes = delete from donation_event where event_type = "gift_subs" and amount = 1 and donation_event.id in ($1)
DuplicateGiftedSubs = '''SELECT donation_event.id, timestamp, amount, login_name, stream_id, origin_id
FROM donation_event
JOIN twitch_user
  ON twitch_user.id = donation_event.donator_twitch_user_id
WHERE timestamp >= "2025-10-15"
AND event_type = "gift_subs"
AND donation_receiver_twitch_user_id = 1
AND origin_id IN (
    SELECT origin_id
    FROM donation_event
    GROUP BY origin_id
    HAVING COUNT(*) > 1
)
ORDER BY timestamp'''
TopDonators = '''SELECT                                                     
  ROW_NUMBER() OVER (ORDER BY SUM(amount) DESC) as `rank`, 
  login_name,                                              
  ROUND(SUM(amount), 2) as total                           
FROM donation_event                                        
JOIN twitch_user                                           
  ON donation_event.donator_twitch_user_id = twitch_user.id
WHERE timestamp >= $1
AND donation_receiver_twitch_user_id = 1
AND event_type = "streamlabs_donation"                     
GROUP BY login_name                                        
ORDER BY total DESC'''
GetData = "SELECT (SELECT COUNT(*) FROM stream_message) as messages, (SELECT COUNT(*) FROM twitch_user) as users"
# example = "SELECT * FROM example_table WHERE id = 1"

# Initial commands to execute when connecting to any database.
[init-commands]
# read_only = "SET SESSION TRANSACTION READ ONLY"


# Use the -d option to reference a DSN.
# Special characters in passwords and other strings can be escaped with URL encoding.
[alias_dsn]
# example_dsn = mysql://[user[:password]@][host][:port][/dbname]

# Initial commands to execute when connecting to a DSN alias.
[alias_dsn.init-commands]
# Define one or more SQL statements per alias (semicolon-separated).
# example_dsn = "SET sql_select_limit=1000; SET time_zone='+00:00'"
